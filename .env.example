# Database
POSTGRES_USER=arxiv_radar
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=arxiv_radar
DATABASE_URL=postgresql+asyncpg://arxiv_radar:changeme_in_production@postgres:5432/arxiv_radar

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=changeme_generate_with_python_secrets_token_urlsafe_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ArXiv ingest
ARXIV_CATEGORIES=cs.CV,cs.LG,cs.CL,cs.AI,cs.NE,cs.RO
ARXIV_INGEST_INTERVAL_MINUTES=30
ARXIV_INGEST_BATCH_SIZE=2000

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
MODEL_CACHE_DIR=/app/model_cache

# Email (optional — for PrivateMail: SMTP_HOST=mail.privateemail.com)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@arxiv-radar.local

# Frontend URL for links in emails (password reset, verification)
FRONTEND_URL=http://localhost:5173

# Semantic Scholar (optional, for citation graph)
SEMANTIC_SCHOLAR_API_KEY=

# Imprint / Legal (required in EU — injected at build time via Vite)
VITE_IMPRINT_COMPANY=
VITE_IMPRINT_REPRESENTATIVE=
VITE_IMPRINT_ADDRESS=
VITE_IMPRINT_EMAIL=
VITE_IMPRINT_PHONE=
VITE_IMPRINT_REGISTER=
VITE_IMPRINT_VAT_ID=

# Security
COOKIE_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
